  /* Mobile: cap canvas/animation heights so text + animation both fit in one viewport */
  @media (max-width: 1023px) {
    .canvas-wrap {
      height: min(240px, 32vh) !important;
      width: min(380px, calc(100vw - 3rem)) !important;
      max-width: 100%;
    }
    /* EKG card: slightly taller to keep stats legible */
    .ekg-wrap {
      height: min(260px, 34vh) !important;
    }
  }
</style>

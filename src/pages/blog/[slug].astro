---
import Layout from '@/layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry('blog', slug);

if (!entry || entry.data.draft) {
  return Astro.redirect('/blog');
}

const { Content } = await entry.render();

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.excerpt,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  author: { '@type': 'Person', name: 'Nitin Mohan' },
  ...(entry.data.coverImage ? { image: entry.data.coverImage } : {}),
};

const faqSchema = entry.data.faqs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: entry.data.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }
  : null;
---

<Layout
  title={`${entry.data.title} — Nitin Mohan`}
  description={entry.data.excerpt}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>
  <article class="min-h-screen pt-32 pb-24 px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 font-mono text-xs text-ivory/30 hover:text-champagne mb-12 transition-all hover:-translate-x-1"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 5l-7 7 7 7" />
        </svg>
        All posts
      </a>

      <!-- Header -->
      <header class="mb-12 space-y-5">
        <div class="flex flex-wrap gap-1.5">
          {entry.data.tags?.map((tag: string) => (
            <span
              class="font-mono text-xs px-3 py-1 rounded-full"
              style="background: rgba(212,148,60,0.08); border: 1px solid rgba(212,148,60,0.2); color: #D4943C;"
            >
              {tag}
            </span>
          ))}
        </div>
        <h1
          class="font-sans font-semibold text-3xl md:text-4xl text-ivory leading-tight"
          style="letter-spacing: -0.03em;"
        >
          {entry.data.title}
        </h1>
        <p class="text-ivory/50 text-lg leading-relaxed">{entry.data.excerpt}</p>
        <div class="flex items-center gap-3">
          <div
            class="w-7 h-7 rounded-full flex items-center justify-center font-mono text-xs font-bold"
            style="background: rgba(212,148,60,0.15); color: #D4943C;"
          >
            N
          </div>
          <div>
            <div class="text-ivory/70 text-sm font-medium">Nitin Mohan</div>
            <div class="font-mono text-xs text-ivory/25">{formatDate(entry.data.date)}</div>
          </div>
        </div>
      </header>

      <!-- Divider -->
      <div class="w-full h-px mb-12" style="background: rgba(250,248,245,0.06);"></div>

      <!-- Cover image -->
      {entry.data.coverImage && (
        <div class="mb-12 rounded-2xl overflow-hidden" style="aspect-ratio: 21/9;">
          <img
            src={entry.data.coverImage}
            alt={entry.data.coverImageAlt ?? entry.data.title}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      )}

      <!-- Article content -->
      <div class="prose-midnight">
        <Content />
      </div>

      <!-- Footer nav -->
      <div class="mt-16 pt-8 flex justify-between items-center" style="border-top: 1px solid rgba(250,248,245,0.06);">
        <a href="/blog" class="btn-ghost text-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7" />
          </svg>
          <span>Back to Blog</span>
        </a>
        <a href="/#contact" class="btn-primary text-sm">
          <span>Get in Touch</span>
        </a>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .prose-midnight {
    color: rgba(250, 248, 245, 0.65);
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose-midnight h2 {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
    font-weight: 600;
    font-size: 1.5rem;
    color: rgba(250, 248, 245, 0.95);
    letter-spacing: -0.025em;
    margin: 2.5rem 0 1rem;
  }

  .prose-midnight h3 {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
    font-weight: 600;
    font-size: 1.15rem;
    color: rgba(250, 248, 245, 0.85);
    margin: 2rem 0 0.75rem;
  }

  .prose-midnight p {
    margin: 1.25rem 0;
  }

  .prose-midnight strong {
    color: rgba(250, 248, 245, 0.9);
    font-weight: 600;
  }

  .prose-midnight em {
    color: #d4943c;
    font-style: italic;
  }

  .prose-midnight code {
    font-family: "SF Mono", Menlo, Monaco, Consolas, monospace;
    font-size: 0.85em;
    background: rgba(212, 148, 60, 0.08);
    border: 1px solid rgba(212, 148, 60, 0.15);
    color: #d4943c;
    padding: 0.15em 0.45em;
    border-radius: 0.375rem;
  }

  .prose-midnight pre {
    background: rgba(250, 248, 245, 0.03);
    border: 1px solid rgba(250, 248, 245, 0.08);
    border-radius: 1rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose-midnight pre code {
    background: none;
    border: none;
    padding: 0;
    color: rgba(250, 248, 245, 0.8);
    font-size: 0.875rem;
  }

  .prose-midnight ul,
  .prose-midnight ol {
    padding-left: 1.5rem;
    margin: 1.25rem 0;
    space-y: 0.5rem;
  }

  .prose-midnight li {
    margin: 0.5rem 0;
  }

  .prose-midnight ul li::marker {
    color: #d4943c;
  }

  .prose-midnight ol li::marker {
    color: rgba(250, 248, 245, 0.3);
  }

  .prose-midnight a {
    color: #d4943c;
    text-decoration: underline;
    text-decoration-color: rgba(212, 148, 60, 0.3);
  }

  .prose-midnight a:hover {
    text-decoration-color: #d4943c;
  }

  .prose-midnight blockquote {
    border-left: 2px solid rgba(212, 148, 60, 0.4);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: rgba(250, 248, 245, 0.45);
    font-style: italic;
  }

  .prose-midnight hr {
    border: none;
    border-top: 1px solid rgba(250, 248, 245, 0.06);
    margin: 2.5rem 0;
  }

  .prose-midnight img {
    width: 100%;
    border-radius: 1rem;
    margin: 2rem 0;
    display: block;
  }

  .prose-midnight table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.875rem;
  }

  .prose-midnight thead th {
    font-family: "SF Mono", Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #d4943c;
    font-weight: 600;
    padding: 0.625rem 1rem;
    border-bottom: 1px solid rgba(212, 148, 60, 0.25);
    text-align: left;
  }

  .prose-midnight td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(250, 248, 245, 0.05);
    vertical-align: top;
    color: rgba(250, 248, 245, 0.65);
    line-height: 1.6;
  }

  .prose-midnight td:first-child {
    font-family: "SF Mono", Menlo, Monaco, Consolas, monospace;
    font-size: 0.8rem;
    color: rgba(250, 248, 245, 0.5);
    white-space: nowrap;
  }

  .prose-midnight tr:last-child td {
    border-bottom: none;
  }

  .prose-midnight tbody tr:hover td {
    background: rgba(212, 148, 60, 0.03);
  }
</style>

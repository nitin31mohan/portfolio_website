---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';

// Fetch dashboard data server-side
let stats: Record<string, number> = {};
let error = '';

try {
  const baseUrl = Astro.url.origin;
  const res = await fetch(`${baseUrl}/api/dashboard-data`, {
    headers: { Cookie: Astro.request.headers.get('Cookie') || '' },
  });
  if (res.ok) {
    stats = await res.json();
  }
} catch (e) {
  error = 'Could not load Redis data.';
}

const campaigns = Object.entries(stats)
  .filter(([k]) => k.startsWith('visit:'))
  .map(([k, v]) => ({ slug: k.replace('visit:', ''), count: v }))
  .sort((a, b) => b.count - a.count);

const qaInteractions = stats['qa:total'] || 0;
const totalVisits = campaigns.reduce((s, c) => s + c.count, 0);
---

<Layout title="Dashboard — Nitin Mohan" description="Analytics dashboard">
  <section class="min-h-screen pt-32 pb-24 px-6">
    <div class="max-w-5xl mx-auto">
      <!-- Header -->
      <div class="mb-12 space-y-3">
        <div class="font-mono text-sm text-champagne/60 tracking-widest uppercase">
          Private Dashboard
        </div>
        <h1
          class="font-sans font-semibold text-4xl md:text-5xl text-ivory"
          style="letter-spacing: -0.03em;"
        >
          Campaign Analytics
        </h1>
        <p class="text-ivory/30 font-mono text-xs">
          Visit counts · QA interactions · Campaign performance
        </p>
      </div>

      {error && (
        <div
          class="mb-8 px-5 py-4 rounded-2xl font-mono text-sm text-red-400"
          style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);"
        >
          {error}
        </div>
      )}

      <!-- Top stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
        {[
          { label: 'Total Campaign Visits', value: totalVisits.toString(), accent: true },
          { label: 'Ask QA Interactions', value: qaInteractions.toString(), accent: false },
          { label: 'Active Campaigns', value: campaigns.length.toString(), accent: false },
        ].map((s) => (
          <div
            class="p-6 rounded-3xl"
            style={`background: rgba(250,248,245,0.03); border: 1px solid ${s.accent ? 'rgba(212,148,60,0.2)' : 'rgba(250,248,245,0.06)'};`}
          >
            <div
              class="font-mono font-bold text-3xl mb-1"
              style={s.accent ? 'color: #D4943C;' : 'color: #FAF8F5;'}
            >
              {s.value}
            </div>
            <div class="font-mono text-xs text-ivory/30">{s.label}</div>
          </div>
        ))}
      </div>

      <!-- Campaign table -->
      <div
        class="rounded-4xl overflow-hidden"
        style="background: rgba(250,248,245,0.02); border: 1px solid rgba(250,248,245,0.07);"
      >
        <div class="px-6 py-4" style="border-bottom: 1px solid rgba(250,248,245,0.06);">
          <div class="font-mono text-xs text-ivory/30 tracking-widest uppercase">
            Campaign Visits
          </div>
        </div>
        {campaigns.length === 0 ? (
          <div class="px-6 py-12 text-center font-mono text-xs text-ivory/20">
            No campaign visits recorded yet. Share your campaign URLs to start tracking.
          </div>
        ) : (
          <div class="divide-y" style="--divide-color: rgba(250,248,245,0.04);">
            {campaigns.map((c) => (
              <div class="flex items-center justify-between px-6 py-4 hover:bg-white/[0.02] transition-colors">
                <div>
                  <div class="font-mono text-sm text-ivory/80">/{c.slug}</div>
                  <div class="font-mono text-xs text-ivory/25 mt-0.5">
                    {Astro.url.origin}/{c.slug}
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <div
                    class="h-1.5 rounded-full"
                    style={`width: ${Math.max(20, Math.min(200, c.count * 10))}px; background: linear-gradient(90deg, rgba(212,148,60,0.4), rgba(212,148,60,0.8));`}
                  ></div>
                  <div class="font-mono text-sm text-champagne font-bold min-w-[2rem] text-right">
                    {c.count}
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Add new campaign hint -->
      <div
        class="mt-6 p-5 rounded-3xl font-mono text-xs text-ivory/25 space-y-1"
        style="background: rgba(250,248,245,0.02); border: 1px solid rgba(250,248,245,0.05); border-style: dashed;"
      >
        <div class="text-ivory/40">Add a new campaign:</div>
        <div>1. Add entry to <code class="text-champagne/70">src/data/campaigns.json</code></div>
        <div>2. Push to GitHub → Vercel redeploys automatically</div>
        <div>3. Share <code class="text-champagne/70">yoursite.com/company-role</code> in the application</div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .divide-y > * + * {
    border-top: 1px solid rgba(250, 248, 245, 0.04);
  }
</style>

#!/usr/bin/env bash
# .githooks/pre-commit
#
# Sanitises PDF metadata for any PDF staged under public/.
# Prevents Word document filenames from leaking into LinkedIn / social
# media link previews via the PDF Title metadata field.

STAGED_PDFS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^public/.*\.pdf$' || true)

if [ -z "$STAGED_PDFS" ]; then
  exit 0
fi

if ! command -v exiftool &> /dev/null; then
  echo ""
  echo "  ⚠  exiftool not found — PDF metadata was NOT sanitised."
  echo "     Install it with: brew install exiftool"
  echo "     Then re-stage and commit."
  echo ""
  exit 1
fi

echo ""
echo "  Checking PDF metadata..."

CHANGED=0
while IFS= read -r pdf; do
  CURRENT_TITLE=$(exiftool -s3 -Title "$pdf" 2>/dev/null || true)
  CLEAN_TITLE="Nitin Mohan — CV"

  if [ "$CURRENT_TITLE" = "$CLEAN_TITLE" ]; then
    echo "  ✓ $pdf  (title already clean)"
    continue
  fi

  echo "  ✎ $pdf"
  echo "      before: ${CURRENT_TITLE:-'(no title set)'}"
  exiftool -Title="$CLEAN_TITLE" -Author="Nitin Mohan" -Subject="" -overwrite_original "$pdf" > /dev/null
  git add "$pdf"
  echo "      after:  $CLEAN_TITLE"
  CHANGED=1
done <<< "$STAGED_PDFS"

if [ "$CHANGED" = "1" ]; then
  echo ""
  echo "  PDF metadata fixed and re-staged. Commit proceeding."
fi

echo ""
